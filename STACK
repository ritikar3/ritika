AWSTemplateFormatVersion: '2010-09-09'

Description: SafeHer Women Safety Emergency Response Serverless Platform

Parameters:
  ProjectName:
    Type: String
    Default: SafeHer

Resources:

  # Cognito Authentication
  SafeHerUserPool:
    Type: AWS::Cognito::UserPool
    Properties:
      UserPoolName: SafeHer-Users
      AutoVerifiedAttributes:
        - email
      UsernameAttributes:
        - email
      Policies:
        PasswordPolicy:
          MinimumLength: 8
          RequireUppercase: true
          RequireLowercase: true
          RequireNumbers: true

  SafeHerUserPoolClient:
    Type: AWS::Cognito::UserPoolClient
    Properties:
      ClientName: SafeHer-App-Client
      UserPoolId: !Ref SafeHerUserPool
      GenerateSecret: false

  # DynamoDB Tables

  UsersTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName: SafeHerUsers
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
        - AttributeName: UserID
          AttributeType: S
      KeySchema:
        - AttributeName: UserID
          KeyType: HASH

  SOSAlertsTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName: SafeHerSOSAlerts
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
        - AttributeName: AlertID
          AttributeType: S
      KeySchema:
        - AttributeName: AlertID
          KeyType: HASH

  GPSTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName: SafeHerGPS
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
        - AttributeName: UserID
          AttributeType: S
      KeySchema:
        - AttributeName: UserID
          KeyType: HASH

  IncidentTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName: SafeHerIncidents
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
        - AttributeName: IncidentID
          AttributeType: S
      KeySchema:
        - AttributeName: IncidentID
          KeyType: HASH

  # S3 Evidence Storage

  SafeHerEvidenceBucket:
    Type: AWS::S3::Bucket
    Properties:
      BucketName: !Sub safeher-evidence-${AWS::AccountId}
      VersioningConfiguration:
        Status: Enabled
      BucketEncryption:
        ServerSideEncryptionConfiguration:
          - ServerSideEncryptionByDefault:
              SSEAlgorithm: AES256

  # SNS Emergency Alerts

  SafeHerEmergencyTopic:
    Type: AWS::SNS::Topic
    Properties:
      TopicName: SafeHer-Emergency-Alerts

  # Lambda IAM Role

  SafeHerLambdaRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName: SafeHer-Lambda-Role
      AssumeRolePolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Effect: Allow
            Principal:
              Service:
                - lambda.amazonaws.com
            Action:
              - sts:AssumeRole

      ManagedPolicyArns:
        - arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole

      Policies:
        - PolicyName: SafeHerBackendAccess
          PolicyDocument:
            Version: "2012-10-17"
            Statement:
              - Effect: Allow
                Action:
                  - dynamodb:*
                  - s3:*
                  - sns:Publish
                Resource: "*"
# Lambda Functions

  SafeHerSOSLambda:
    Type: AWS::Lambda::Function
    Properties:
      FunctionName: SafeHer-SOS-Processor
      Runtime: python3.12
      Handler: index.lambda_handler
      Role: !GetAtt SafeHerLambdaRole.Arn
      Timeout: 15
      Environment:
        Variables:
          SOS_TABLE: !Ref SOSAlertsTable
          SNS_TOPIC: !Ref SafeHerEmergencyTopic
      Code:
        ZipFile: |
          import json,boto3,uuid,os

          dynamodb=boto3.resource('dynamodb')
          sns=boto3.client('sns')
          table=dynamodb.Table(os.environ['SOS_TABLE'])

          def lambda_handler(event,context):
              alert_id=str(uuid.uuid4())

              table.put_item(
                  Item={
                    "AlertID":alert_id,
                    "Status":"ACTIVE"
                  }
              )

              sns.publish(
                  TopicArn=os.environ['SNS_TOPIC'],
                  Message="SafeHer Emergency SOS Triggered"
              )

              return {
                "statusCode":200,
                "body":json.dumps({
                  "message":"SOS Alert Sent",
                  "AlertID":alert_id
                })
              }


  SafeHerGPSLambda:
    Type: AWS::Lambda::Function
    Properties:
      FunctionName: SafeHer-GPS-Tracker
      Runtime: python3.12
      Handler: index.lambda_handler
      Role: !GetAtt SafeHerLambdaRole.Arn
      Environment:
        Variables:
          GPS_TABLE: !Ref GPSTable
      Code:
        ZipFile: |
          import boto3,os

          table=boto3.resource('dynamodb').Table(
              os.environ['GPS_TABLE']
          )

          def lambda_handler(event,context):
              table.put_item(
                Item={
                  "UserID":event["userId"],
                  "Latitude":event["latitude"],
                  "Longitude":event["longitude"]
                }
              )

              return {
                "statusCode":200,
                "body":"Location Saved"
              }


  SafeHerEvidenceLambda:
    Type: AWS::Lambda::Function
    Properties:
      FunctionName: SafeHer-Evidence-Upload
      Runtime: python3.12
      Handler: index.lambda_handler
      Role: !GetAtt SafeHerLambdaRole.Arn
      Environment:
        Variables:
          BUCKET: !Ref SafeHerEvidenceBucket
      Code:
        ZipFile: |
          import json

          def lambda_handler(event,context):
              return {
                "statusCode":200,
                "body":json.dumps({
                  "message":"Evidence Upload Ready"
                })
              }


# API Gateway

  SafeHerAPI:
    Type: AWS::ApiGateway::RestApi
    Properties:
      Name: SafeHer-Emergency-API


  SafeHerAuthorizer:
    Type: AWS::ApiGateway::Authorizer
    Properties:
      Name: SafeHer-Cognito-Authorizer
      Type: COGNITO_USER_POOLS
      RestApiId: !Ref SafeHerAPI
      IdentitySource: method.request.header.Authorization
      ProviderARNs:
        - !GetAtt SafeHerUserPool.Arn


# API Resources

  SOSApiResource:
    Type: AWS::ApiGateway::Resource
    Properties:
      RestApiId: !Ref SafeHerAPI
      ParentId: !GetAtt SafeHerAPI.RootResourceId
      PathPart: sos


  GPSApiResource:
    Type: AWS::ApiGateway::Resource
    Properties:
      RestApiId: !Ref SafeHerAPI
      ParentId: !GetAtt SafeHerAPI.RootResourceId
      PathPart: location


# API Methods

  SOSMethod:
    Type: AWS::ApiGateway::Method
    Properties:
      RestApiId: !Ref SafeHerAPI
      ResourceId: !Ref SOSApiResource
      HttpMethod: POST
      AuthorizationType: COGNITO_USER_POOLS
      AuthorizerId: !Ref SafeHerAuthorizer
      Integration:
        Type: AWS_PROXY
        IntegrationHttpMethod: POST
        Uri: !Sub arn:aws:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${SafeHerSOSLambda.Arn}/invocations


  GPSMethod:
    Type: AWS::ApiGateway::Method
    Properties:
      RestApiId: !Ref SafeHerAPI
      ResourceId: !Ref GPSApiResource
      HttpMethod: POST
      AuthorizationType: COGNITO_USER_POOLS
      AuthorizerId: !Ref SafeHerAuthorizer
      Integration:
        Type: AWS_PROXY
        IntegrationHttpMethod: POST
        Uri: !Sub arn:aws:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${SafeHerGPSLambda.Arn}/invocations


# Lambda Permissions

  AllowAPIGatewaySOS:
    Type: AWS::Lambda::Permission
    Properties:
      FunctionName: !Ref SafeHerSOSLambda
      Action: lambda:InvokeFunction
      Principal: apigateway.amazonaws.com


  AllowAPIGatewayGPS:
    Type: AWS::Lambda::Permission
    Properties:
      FunctionName: !Ref SafeHerGPSLambda
      Action: lambda:InvokeFunction
      Principal: apigateway.amazonaws.com
# API Gateway Deployment

  SafeHerAPIDeployment:
    Type: AWS::ApiGateway::Deployment
    DependsOn:
      - SOSMethod
      - GPSMethod
    Properties:
      RestApiId: !Ref SafeHerAPI
      StageName: prod


# CloudWatch Monitoring

  SOSLambdaLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName: /aws/lambda/SafeHer-SOS-Processor
      RetentionInDays: 30

  GPSLambdaLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName: /aws/lambda/SafeHer-GPS-Tracker
      RetentionInDays: 30

  EvidenceLambdaLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName: /aws/lambda/SafeHer-Evidence-Upload
      RetentionInDays: 30


# AWS Amplify Frontend

  SafeHerAmplifyApp:
    Type: AWS::Amplify::App
    Properties:
      Name: SafeHer-Frontend
      Description: SafeHer React Frontend Application
      BuildSpec: |
        version: 1
        frontend:
          phases:
            preBuild:
              commands:
                - npm install
            build:
              commands:
                - npm run build
          artifacts:
            baseDirectory: build
            files:
              - '**/*'
          cache:
            paths:
              - node_modules/**/*


  SafeHerAmplifyBranch:
    Type: AWS::Amplify::Branch
    Properties:
      AppId: !GetAtt SafeHerAmplifyApp.AppId
      BranchName: main
      EnableAutoBuild: true


# Outputs

Outputs:

  CognitoUserPoolID:
    Description: Cognito User Pool Identifier
    Value: !Ref SafeHerUserPool

  CognitoClientID:
    Description: Cognito Application Client ID
    Value: !Ref SafeHerUserPoolClient

  APIEndpoint:
    Description: API Gateway Endpoint
    Value: !Sub https://${SafeHerAPI}.execute-api.${AWS::Region}.amazonaws.com/prod

  SOSDatabase:
    Description: SOS DynamoDB Table
    Value: !Ref SOSAlertsTable

  GPSDatabase:
    Description: GPS DynamoDB Table
    Value: !Ref GPSTable

  EvidenceStorage:
    Description: S3 Evidence Bucket
    Value: !Ref SafeHerEvidenceBucket

  EmergencyNotificationTopic:
    Description: SNS Emergency Topic
    Value: !Ref SafeHerEmergencyTopic

  AmplifyApplicationID:
    Description: Amplify Frontend Application ID
    Value: !GetAtt SafeHerAmplifyApp.AppId
